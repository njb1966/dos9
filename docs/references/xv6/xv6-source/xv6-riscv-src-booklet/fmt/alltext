8205 int
8206 gettoken(char **ps, char *es, char **q, char **eq)
8207 {
8208   char *s;
8209   int ret;
8210 
8211   s = *ps;
8212   while(s < es && strchr(whitespace, *s))
8213     s++;
8214   if(q)
8215     *q = s;
8216   ret = *s;
8217   switch(*s){
8218   case 0:
8219     break;
8220   case '|':
8221   case '(':
8222   case ')':
8223   case ';':
8224   case '&':
8225   case '<':
8226     s++;
8227     break;
8228   case '>':
8229     s++;
8230     if(*s == '>'){
8231       ret = '+';
8232       s++;
8233     }
8234     break;
8235   default:
8236     ret = 'a';
8237     while(s < es && !strchr(whitespace, *s) && !strchr(symbols, *s))
8238       s++;
8239     break;
8240   }
8241   if(eq)
8242     *eq = s;
8243 
8244   while(s < es && strchr(whitespace, *s))
8245     s++;
8246   *ps = s;
8247   return ret;
8248 }
