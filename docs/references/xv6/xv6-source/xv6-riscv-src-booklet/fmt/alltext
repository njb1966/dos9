1663   if(PGROUNDUP(newsz) < PGROUNDUP(oldsz)){
1664     int npages = (PGROUNDUP(oldsz) - PGROUNDUP(newsz)) / PGSIZE;
1665     uvmunmap(pagetable, PGROUNDUP(newsz), npages, 1);
