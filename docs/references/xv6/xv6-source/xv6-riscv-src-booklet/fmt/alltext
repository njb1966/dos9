8250 int
8251 peek(char **ps, char *es, char *toks)
8252 {
8253   char *s;
8254 
8255   s = *ps;
8256   while(s < es && strchr(whitespace, *s))
8257     s++;
8258   *ps = s;
8259   return *s && strchr(toks, *s);
8260 }
