8267 struct cmd*
8268 parsecmd(char *s)
8269 {
8270   char *es;
8271   struct cmd *cmd;
8272 
8273   es = s + strlen(s);
8274   cmd = parseline(&s, es);
8275   peek(&s, es, "");
8276   if(s != es){
8277     fprintf(2, "leftovers: %s\n", s);
8278     panic("syntax");
8279   }
8280   nulterminate(cmd);
8281   return cmd;
8282 }
